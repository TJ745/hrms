  id             String          @id @default(cuid())
  organizationId String
  type           IntegrationType
  name           String
  config         Json // encrypted config
  isActive       Boolean         @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("integrations")
}

model FeatureFlag {
  id             String   @id @default(cuid())
  organizationId String
  feature        String
  isEnabled      Boolean  @default(true)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, feature])
  @@map("feature_flags")
}

// ============================================================
// FILE REGISTRY
// ============================================================

model FileRecord {
  id             String   @id @default(cuid())
  organizationId String
  uploadedBy     String
  entityType     String // "employee", "payslip", "contract"
  entityId       String
  fileName       String
  fileSize       Int // bytes
  mimeType       String
  cloudinaryId   String
  url            String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("file_records")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String // CREATE, UPDATE, DELETE, LOGIN, EXPORT
  entity         String // "Employee", "Payroll", "LeaveRequest"
  entityId       String?
  oldValues      Json?
  newValues      Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
